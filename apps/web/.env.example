# --- Optional: connect to the FastAPI backend in services/api ---
# When set, the preview studio routes intake/checkout/follow-up through FastAPI.
# Leave unset on Vercel to use the built-in serverless preview engine.
# NEXT_PUBLIC_CHEKA_API_URL=http://127.0.0.1:8000

# --- Optional: enable AI analysis & follow-ups ---
# Set this in Vercel → Project Settings → Environment Variables.
# Without it the app falls back to the built-in rule-based engine.
# OPENAI_API_KEY=sk-...

# Optional model overrides (defaults shown)
# OPENAI_ANALYSIS_MODEL=gpt-4o-mini
# OPENAI_FOLLOW_UP_MODEL=gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o-mini

# --- Optional: enable internal admin route at /admin ---
# NEXT_PUBLIC_ENABLE_ADMIN_STUDIO=false
